# Second Brain Environment Variables
SB_DATABASE_URL=postgresql+asyncpg://brain:brain@db:5432/secondbrain
SB_DATABASE_URL_SYNC=postgresql://brain:brain@db:5432/secondbrain
SB_DEBUG=true
SB_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
SB_ENRICHED_SCHEMA_PATH=/app/schemas/enriched_contract.schema.json
SB_MAX_RAW_PAYLOAD_CHARS=12000

# LLM provider for auto-process feature (anthropic | google | openai)
SB_LLM_PROVIDER=anthropic
# Model name matching the provider (e.g. claude-haiku-4-5, gemini-pro, gpt-4o-mini)
SB_LLM_MODEL=claude-haiku-4-5
# API key for the selected provider
SB_LLM_API_KEY=your_api_key_here

# MCP Server port (default 8001)
SB_MCP_PORT=8001
# MCP Server backend URL (where FastAPI runs, inside Docker: http://brain-core:8000)
SB_MCP_API_BASE=http://brain-core:8000
